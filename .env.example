# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Get your Anthropic API key at: https://console.anthropic.com/

# ─── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────────────────────────────────────
# Path to the SQLite database file (default: ./data/translations.db)
# DATABASE_PATH=./data/translations.db

# Extra origins to allow in CORS (comma-separated), e.g. your Railway domain
# ALLOWED_ORIGINS=https://your-app.railway.app

# ─── Railway deployment checklist ────────────────────────────────────────────
# 1. Go to your Railway project → Variables tab.
# 2. Add ANTHROPIC_API_KEY with your key value (never paste it in railway.toml).
# 3. Railway injects PORT automatically — do not set it manually.
# 4. Optionally add ALLOWED_ORIGINS if your frontend runs on a separate domain.
# 5. Confirm the key is present: railway run printenv | grep ANTHROPIC
#    (or check the Deploy Logs for "serving on port …" without startup errors).
# 6. The key is server-side only. It is never sent to the browser or exposed
#    in client bundles.
